DISCORD_TOKEN=replace-with-your-bot-token
# BUS_HOST must remain a loopback address; the bus trusts only loopback peers.
BUS_HOST=127.0.0.1
BUS_PORT=8765
BUS_TOKEN=generate-a-random-256-bit-hex-string
WRITE_ENABLED=true
ALLOWED_GUILD_IDS=
DEFAULT_GUILD_ID=
LOG_LEVEL=INFO
SENTRY_DSN=
AUDIT_PATH=./audit.jsonl
